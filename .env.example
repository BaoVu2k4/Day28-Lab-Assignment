# .env.example — copy sang .env và chỉnh sửa
# -----------------------------------------------------------------------------
# CHẾ ĐỘ MẶC ĐỊNH (self-contained, không cần Kaggle):
#   Để trống VLLM_NGROK_URL / EMBED_NGROK_URL => API Gateway tự dùng mock GPU
#   services chạy local trong Docker (mock-vllm:8001, mock-embed:8002).
#
# CHẾ ĐỘ PRODUCTION (dùng Kaggle GPU thật):
#   Điền URL ngrok/cloudflared lấy từ Kaggle notebook vào 2 biến dưới.
# -----------------------------------------------------------------------------

# vLLM serving trên Kaggle (để trống = dùng mock local)
VLLM_NGROK_URL=

# Embedding service trên Kaggle (để trống = dùng mock local)
EMBED_NGROK_URL=

# ngrok token dùng trong Kaggle notebook để expose vLLM/embedding (không commit token thật)
NGROK_AUTHTOKEN=

# Model name gửi tới vLLM
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-GPTQ-Int4

# LangSmith tracing (tùy chọn — để trống sẽ bỏ qua tracing, không lỗi)
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lab28-platform
LANGCHAIN_TRACING_V2=false
